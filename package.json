{
  "name": "boiler-plate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"next,prisma,email\" -c \"black,magenta,cyan\" \"pnpm dev:next\" \"pnpm dev:prisma\" \"pnpm dev:email\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "generate": "prisma generate && prisma migrate dev",
    "dev:next": "next dev --turbopack --port 3000",
    "dev:prisma": "prisma studio --port 5555 --browser none",
    "dev:email": "email dev --port 3001 --dir ./lib/mails",
    "test": "jest"
  },
